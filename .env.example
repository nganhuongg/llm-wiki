# Copy to .env and fill in. .env is gitignored.

# LLM
LLM_API_KEY=sk-...                # required
# LLM_PROVIDER=openai             # optional, defaults to openai
# LLM_MODEL=gpt-4o-mini           # optional, see docs.cognee.ai/setup-configuration/llm-providers

# Embedding (cognee defaults to OpenAI text-embedding-3-large; usually no override needed)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_API_KEY=sk-...

# Redis - session memory
REDIS_URL=redis://localhost:6379
