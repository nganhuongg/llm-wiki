# Copy to .env and fill in. .env is gitignored.

# LLM
LLM_API_KEY=sk-...                # required
# LLM_PROVIDER=openai             # optional, defaults to openai
# LLM_MODEL=openai/gpt-5-mini     # optional, see docs.cognee.ai/setup-configuration/llm-providers

# Embedding (cognee defaults to OpenAI text-embedding-3-large; usually no override needed)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_API_KEY=sk-...

# Demo safety: local wiki search + LLM synthesis is the default query path.
# Set true only if Cognee recall is populated and responding quickly.
ENABLE_COGNEE_RECALL=false

# Redis - session memory
REDIS_URL=redis://localhost:6379

# Demo time acceleration. Divides real TTLs by this factor so the
# forgetting curve plays out in the 3-minute demo. 100 means
# "1 day of decay = ~14 seconds on stage." Set to 1 for production.
DEMO_TIME_SCALE=100
